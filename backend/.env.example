# Server
PORT=5000
NODE_ENV=development

# Database (use MongoDB Atlas or local MongoDB)
MONGODB_URI=mongodb://localhost:27017/ai-resume-generator

# Hugging Face — use a token with "Inference Providers" (fine-grained) or classic with inference access
# https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_token_here

# Optional: router model id (Inference Providers). Suffixes: :fastest :cheapest :preferred or :provider
# HF_MODEL=Qwen/Qwen2.5-7B-Instruct:fastest

# Frontend URL (for CORS - use your deployed frontend URL in production)
FRONTEND_URL=http://localhost:3000
