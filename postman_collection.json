								"api",
								"auth",
								"login"
							]
						},
						"description": "Login with existing user credentials"
					}
				},
				{
					"name": "Get Current User",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"description": "Replace {{token}} with the token received from login"
							}
						],
						"url": {
							"raw": "http://localhost:5002/api/auth/me",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "5002",
							"path": [
								"api",
								"auth",
								"me"
							]
						},
						"description": "Get current user information (requires authentication)"
					}
				}
